{% layout 'theme' %}
<section class="section">
  <div class="container container--narrow" style="max-width:480px;text-align:center;">
    <h1 style="font-size:var(--text-h2);margin-bottom:var(--space-8);">{{ 'customer.reset_password.title' | t }}</h1>
    {%- form 'reset_customer_password' -%}
      {{ form.errors | default_errors }}
      <div class="field" style="margin-bottom:var(--space-4);text-align:left;">
        <label class="field__label" for="Password">{{ 'customer.reset_password.password' | t }}</label>
        <input class="field__input" type="password" name="customer[password]" id="Password" required>
      </div>
      <div class="field" style="margin-bottom:var(--space-6);text-align:left;">
        <label class="field__label" for="PasswordConfirmation">{{ 'customer.reset_password.password_confirm' | t }}</label>
        <input class="field__input" type="password" name="customer[password_confirmation]" id="PasswordConfirmation" required>
      </div>
      <button type="submit" class="btn btn--primary btn--full btn--lg">{{ 'customer.reset_password.submit' | t }}</button>
    {%- endform -%}
  </div>
</section>
