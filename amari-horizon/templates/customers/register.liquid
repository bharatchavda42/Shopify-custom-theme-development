{% layout 'theme' %}
<section class="section">
  <div class="container container--narrow" style="max-width:480px;">
    <h1 style="font-size:var(--text-h2);margin-bottom:var(--space-8);text-align:center;">{{ 'customer.register.title' | t }}</h1>
    {%- form 'create_customer' -%}
      {{ form.errors | default_errors }}
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:var(--space-4);margin-bottom:var(--space-4);">
        <div class="field">
          <label class="field__label" for="FirstName">{{ 'customer.register.first_name' | t }}</label>
          <input class="field__input" type="text" name="customer[first_name]" id="FirstName" autocomplete="given-name">
        </div>
        <div class="field">
          <label class="field__label" for="LastName">{{ 'customer.register.last_name' | t }}</label>
          <input class="field__input" type="text" name="customer[last_name]" id="LastName" autocomplete="family-name">
        </div>
      </div>
      <div class="field" style="margin-bottom:var(--space-4);">
        <label class="field__label" for="Email">{{ 'customer.register.email' | t }}</label>
        <input class="field__input" type="email" name="customer[email]" id="Email" autocomplete="email" required>
      </div>
      <div class="field" style="margin-bottom:var(--space-6);">
        <label class="field__label" for="CreatePassword">{{ 'customer.register.password' | t }}</label>
        <input class="field__input" type="password" name="customer[password]" id="CreatePassword" autocomplete="new-password" required>
      </div>
      <button type="submit" class="btn btn--primary btn--full btn--lg">{{ 'customer.register.submit' | t }}</button>
    {%- endform -%}
    <p style="text-align:center;margin-top:var(--space-6);font-size:var(--text-sm);">
      <a href="{{ routes.account_login_url }}">{{ 'customer.login.title' | t }}</a>
    </p>
  </div>
</section>
