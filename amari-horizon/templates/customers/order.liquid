{% layout 'theme' %}
<section class="section">
  <div class="container">
    <a href="{{ routes.account_url }}" style="font-size:var(--text-sm);color:var(--color-text-muted);margin-bottom:var(--space-6);display:inline-block;">&larr; Back to Account</a>
    <h1 style="font-size:var(--text-h2);margin-bottom:var(--space-8);">Order {{ order.name }}</h1>
    <p style="color:var(--color-text-muted);margin-bottom:var(--space-8);">Placed on {{ order.created_at | date: '%B %d, %Y' }} &bull; {{ order.financial_status_label }}</p>
    <div style="display:grid;grid-template-columns:2fr 1fr;gap:var(--space-12);">
      <div>
        {%- for line_item in order.line_items -%}
          <div style="display:flex;gap:var(--space-5);padding-block:var(--space-5);border-bottom:1px solid var(--color-border);">
            {%- if line_item.image -%}
              <img src="{{ line_item.image | image_url: width: 120 }}" alt="{{ line_item.title }}" style="width:80px;height:80px;object-fit:cover;" loading="lazy">
            {%- endif -%}
            <div style="flex:1;">
              <p style="font-weight:var(--weight-bold);">{{ line_item.product.title }}</p>
              {%- unless line_item.variant.title == 'Default Title' -%}
                <p style="font-size:var(--text-sm);color:var(--color-text-muted);">{{ line_item.variant.title }}</p>
              {%- endunless -%}
              <p style="font-size:var(--text-sm);">Qty: {{ line_item.quantity }}</p>
            </div>
            <p style="font-weight:var(--weight-bold);">{{ line_item.final_line_price | money }}</p>
          </div>
        {%- endfor -%}
      </div>
      <div>
        <div style="border:1px solid var(--color-border);padding:var(--space-6);">
          <h2 style="font-size:var(--text-h6);margin-bottom:var(--space-5);">Order Summary</h2>
          <div style="display:flex;justify-content:space-between;margin-bottom:var(--space-2);"><span>Subtotal</span><span>{{ order.subtotal_price | money }}</span></div>
          <div style="display:flex;justify-content:space-between;margin-bottom:var(--space-2);"><span>Shipping</span><span>{{ order.shipping_price | money }}</span></div>
          <div style="display:flex;justify-content:space-between;margin-bottom:var(--space-2);"><span>Tax</span><span>{{ order.tax_price | money }}</span></div>
          <hr style="border:none;border-top:1px solid var(--color-border);margin-block:var(--space-4);">
          <div style="display:flex;justify-content:space-between;font-weight:var(--weight-bold);font-size:var(--text-lg);"><span>Total</span><span>{{ order.total_price | money }}</span></div>
        </div>
      </div>
    </div>
  </div>
</section>
