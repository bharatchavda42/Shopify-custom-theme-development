<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{ shop.name }} — {{ 'general.password_page.opening_soon' | t }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Albert+Sans:wght@700&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet">
  {{ content_for_header }}
  {{ 'tokens.css' | asset_url | stylesheet_tag }}
  {{ 'base.css'   | asset_url | stylesheet_tag }}
  <style>
    body { display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100vh; background: var(--color-bg-dark); color: #FFFFFF; text-align: center; padding: var(--space-8); }
    .password__logo { font-family: var(--font-heading); font-size: var(--text-h2); font-weight: var(--weight-bold); letter-spacing: var(--tracking-widest); color: #FFFFFF; margin-bottom: var(--space-12); }
    .password__heading { font-size: var(--text-h3); margin-bottom: var(--space-4); }
    .password__subtext { color: rgba(255,255,255,0.65); margin-bottom: var(--space-10); }
    .password__form { display: flex; gap: 0; max-width: 400px; width: 100%; }
    .password__input { flex: 1; padding: 16px; border: none; background: rgba(255,255,255,0.1); color: #FFFFFF; font-size: var(--text-base); }
    .password__input::placeholder { color: rgba(255,255,255,0.4); }
    .password__input:focus { outline: none; background: rgba(255,255,255,0.15); }
    .password__btn { background: var(--color-primary); color: var(--color-heading); font-weight: var(--weight-bold); padding: 16px 24px; border: none; cursor: pointer; }
  </style>
</head>
<body>
  <div class="password__logo">{{ shop.name }}</div>
  <h1 class="password__heading">{{ 'general.password_page.opening_soon' | t }}</h1>
  <p class="password__subtext">{{ 'general.password_page.login_form_heading' | t }}</p>
  {% form 'storefront_password' %}
    <div class="password__form">
      <input class="password__input" type="password" name="password" placeholder="{{ 'general.password_page.password_placeholder' | t }}">
      <button class="password__btn" type="submit">{{ 'general.password_page.submit_button' | t }}</button>
    </div>
    {{ form.errors | default_errors }}
  {% endform %}
  {{ content_for_layout }}
</body>
</html>
