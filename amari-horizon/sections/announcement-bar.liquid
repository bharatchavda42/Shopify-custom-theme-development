{% comment %} Section: Announcement Bar — Amari Horizon {% endcomment %}

{%- if section.settings.show_announcement -%}
  {{ 'section-announcement-bar.css' | asset_url | stylesheet_tag }}

  <div
    class="announcement-bar"
    id="shopify-section-{{ section.id }}"
    role="region"
    aria-label="Announcement"
    style="
      --ab-bg: {{ section.settings.bg_color }};
      --ab-color: {{ section.settings.text_color }};
      --ab-font-size: {{ section.settings.font_size }}px;
    "
  >
    <p class="announcement-bar__text">
      {%- if section.settings.link != blank -%}
        <a href="{{ section.settings.link }}" class="announcement-bar__link">
          {{ section.settings.text | escape }}
        </a>
      {%- else -%}
        {{ section.settings.text | escape }}
      {%- endif -%}
    </p>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement Bar",
  "tag": "div",
  "class": "announcement-bar-section",
  "settings": [
    { "type": "checkbox", "id": "show_announcement", "label": "Show announcement bar", "default": true },
    { "type": "text", "id": "text", "label": "Announcement text", "default": "Free shipping on orders over $100 — Shop New Arrivals" },
    { "type": "url", "id": "link", "label": "Announcement link" },
    { "type": "color", "id": "bg_color", "label": "Background color", "default": "#1A1A1A" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#FFFFFF" },
    { "type": "range", "id": "font_size", "min": 12, "max": 18, "step": 1, "unit": "px", "label": "Font size", "default": 14 }
  ],
  "presets": [
    {
      "name": "Announcement Bar",
      "settings": {
        "show_announcement": true,
        "text": "Free shipping on orders over $100 — Shop New Arrivals",
        "bg_color": "#1A1A1A",
        "text_color": "#FFFFFF",
        "font_size": 14
      }
    }
  ]
}
{% endschema %}
