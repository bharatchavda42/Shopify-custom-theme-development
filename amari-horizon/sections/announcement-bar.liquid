{%- if section.settings.show_announcement -%}
<div class="announcement-bar" style="background-color:{{ section.settings.bg_color }};color:{{ section.settings.text_color }};">
  <div class="announcement-bar__inner">
    {%- if section.settings.link != blank -%}
      <a href="{{ section.settings.link }}" class="announcement-bar__text">{{ section.settings.text }}</a>
    {%- else -%}
      <span class="announcement-bar__text">{{ section.settings.text }}</span>
    {%- endif -%}
  </div>
</div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement Bar",
  "class": "announcement-bar-section",
  "settings": [
    { "type": "checkbox", "id": "show_announcement", "label": "Show announcement", "default": true },
    { "type": "text",  "id": "text",     "label": "Text",       "default": "Free shipping on orders over $100 — Use code FREESHIP" },
    { "type": "url",   "id": "link",     "label": "Link"  },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#1A1A1A" },
    { "type": "color", "id": "text_color","label": "Text color","default": "#FFFFFF" }
  ]
}
{% endschema %}
