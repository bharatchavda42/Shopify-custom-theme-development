{% comment %} Section: Promo Banners — Amari Horizon {% endcomment %}

{{ 'section-promo-banners.css' | asset_url | stylesheet_tag }}

<section
  class="promo-banners"
  id="shopify-section-{{ section.id }}"
  style="
    --pb-gap: {{ section.settings.banner_gap }}px;
    --pb-padding-top: {{ section.settings.padding_top }}px;
    --pb-padding-bottom: {{ section.settings.padding_bottom }}px;
    --pb-radius: {{ section.settings.banner_radius }}px;
  "
>
  <div class="page-width promo-banners__inner">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'banner' -%}
          <div
            class="promo-banners__banner"
            {{ block.shopify_attributes }}
            style="
              --pb-item-radius: {{ block.settings.radius | default: section.settings.banner_radius }}px;
            "
          >
            <div class="promo-banners__media">
              {%- if block.settings.image != blank -%}
                {{
                  block.settings.image
                  | image_url: width: 800
                  | image_tag:
                    class: 'promo-banners__image',
                    loading: 'lazy',
                    widths: '400,600,800',
                    sizes: '(max-width: 749px) 100vw, 50vw'
                }}
              {%- else -%}
                <div class="promo-banners__placeholder">{{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}</div>
              {%- endif -%}
              <div class="promo-banners__overlay" style="background: linear-gradient(to bottom, transparent 40%, rgba(0,0,0,0.35) 100%);"></div>
            </div>

            <div class="promo-banners__content" style="text-align:{{ block.settings.content_align }}">;
              {%- if block.settings.label != blank -%}
                <p class="promo-banners__label">{{ block.settings.label }}</p>
              {%- endif -%}
              {%- if block.settings.title != blank -%}
                <h2 class="promo-banners__title">{{ block.settings.title }}</h2>
              {%- endif -%}
              {%- if block.settings.button_label != blank -%}
                <a
                  href="{{ block.settings.button_url | default: '/collections/all' }}"
                  class="promo-banners__btn"
                >{{ block.settings.button_label }}</a>
              {%- endif -%}
            </div>
          </div>
      {%- endcase -%}
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Promo Banners",
  "tag": "section",
  "class": "section-promo-banners",
  "settings": [
    { "type": "range", "id": "banner_gap", "min": 0, "max": 60, "step": 4, "unit": "px", "label": "Gap between banners", "default": 30 },
    { "type": "range", "id": "banner_radius", "min": 0, "max": 40, "step": 4, "unit": "px", "label": "Banner radius", "default": 0 },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 8, "unit": "px", "label": "Padding top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 8, "unit": "px", "label": "Padding bottom", "default": 80 }
  ],
  "blocks": [
    {
      "type": "banner",
      "name": "Promo Banner",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Banner image" },
        { "type": "text", "id": "label", "label": "Label (small text)", "default": "Hurry up!" },
        { "type": "text", "id": "title", "label": "Title", "default": "SALE IS LIVE" },
        { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop The Collection" },
        { "type": "url", "id": "button_url", "label": "Button link" },
        {
          "type": "select",
          "id": "content_align",
          "label": "Content alignment",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ],
          "default": "center"
        },
        { "type": "range", "id": "radius", "min": 0, "max": 40, "step": 4, "unit": "px", "label": "Corner radius", "default": 0 }
      ]
    }
  ],
  "presets": [
    {
      "name": "Promo Banners",
      "settings": {
        "banner_gap": 30,
        "banner_radius": 0,
        "padding_top": 80,
        "padding_bottom": 80
      },
      "blocks": [
        {
          "type": "banner",
          "settings": {
            "label": "Hurry up!",
            "title": "SALE IS LIVE",
            "button_label": "Shop The Collection",
            "content_align": "center"
          }
        },
        {
          "type": "banner",
          "settings": {
            "label": "Winter Collection",
            "title": "NEW ARRIVAL",
            "button_label": "Shop The Collection",
            "content_align": "center"
          }
        }
      ]
    }
  ]
}
{% endschema %}
