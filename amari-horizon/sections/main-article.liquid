<article class="section">
  <div class="container container--narrow">
    {%- render 'breadcrumbs' -%}
    {%- if article.image -%}
      <div style="aspect-ratio:16/9;overflow:hidden;margin-bottom:var(--space-10);">
        <img src="{{ article.image | image_url: width: 1200 }}" alt="{{ article.image.alt | default: article.title }}" style="width:100%;height:100%;object-fit:cover;" loading="eager" width="1200" height="675">
      </div>
    {%- endif -%}
    <p style="font-size:var(--text-xs);font-weight:var(--weight-bold);letter-spacing:var(--tracking-widest);text-transform:uppercase;color:var(--color-text-muted);margin-bottom:var(--space-3);">{{ article.published_at | date: '%B %d, %Y' }} &bull; {{ article.author }}</p>
    <h1 style="font-size:var(--text-h2);margin-bottom:var(--space-8);">{{ article.title }}</h1>
    <div style="font-size:var(--text-base);line-height:var(--leading-relaxed);">{{ article.content }}</div>
    <div style="margin-top:var(--space-10);padding-top:var(--space-10);border-top:1px solid var(--color-border);">
      <a href="{{ blog.url }}" style="font-size:var(--text-sm);font-weight:var(--weight-bold);letter-spacing:var(--tracking-wider);text-transform:uppercase;">&larr; Back to {{ blog.title }}</a>
    </div>
  </div>
</article>

{% schema %}
{
  "name": "Article",
  "settings": [],
  "presets": [{ "name": "Article" }]
}
{% endschema %}
