<section class="section" style="background-color:{{ section.settings.bg_color }};">
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <h2 class="section-header__title" style="text-align:center;margin-bottom:var(--space-12);">{{ section.settings.heading }}</h2>
    {%- endif -%}
    <div class="lookbook">
      {%- if section.settings.video_url != blank -%}
        <div style="position:relative;padding-top:56.25%;border-radius:var(--radius-md);overflow:hidden;">
          <iframe src="{{ section.settings.video_url }}" style="position:absolute;inset:0;width:100%;height:100%;border:none;" allow="autoplay;fullscreen" loading="lazy" title="{{ section.settings.heading }}"></iframe>
        </div>
      {%- elsif section.settings.cover_image != blank -%}
        <div style="position:relative;aspect-ratio:16/9;border-radius:var(--radius-md);overflow:hidden;cursor:pointer;" id="VideoTrigger">
          <img src="{{ section.settings.cover_image | image_url: width: 1440 }}" alt="{{ section.settings.cover_image.alt }}" style="width:100%;height:100%;object-fit:cover;" loading="lazy" width="1440" height="810">
          <div class="lookbook__play">
            <div class="lookbook__play-btn">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
            </div>
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Video",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Fashion in Motion" },
    { "type": "video_url", "id": "video_url", "label": "Video URL", "accept": ["youtube", "vimeo"] },
    { "type": "image_picker", "id": "cover_image", "label": "Cover image (fallback)" },
    { "type": "color", "id": "bg_color", "label": "Background color", "default": "#FFFFFF" }
  ],
  "presets": [{ "name": "Video" }]
}
{% endschema %}
