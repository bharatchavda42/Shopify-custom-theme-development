<section class="section" style="text-align:center;min-height:60vh;display:flex;align-items:center;">
  <div class="container">
    <p style="font-size:100px;font-weight:var(--weight-bold);line-height:1;color:var(--color-border);margin-bottom:var(--space-4);">404</p>
    <h1 style="font-size:var(--text-h2);margin-bottom:var(--space-4);">{{ 'sections.404.title' | t }}</h1>
    <p style="font-size:var(--text-lg);color:var(--color-text-muted);margin-bottom:var(--space-10);">{{ 'sections.404.subtitle' | t }}</p>
    <a href="{{ routes.root_url }}" class="btn btn--primary btn--lg">{{ 'sections.404.back_to_home' | t }}</a>
  </div>
</section>

{% schema %}
{
  "name": "404",
  "settings": [],
  "presets": [{ "name": "404" }]
}
{% endschema %}
