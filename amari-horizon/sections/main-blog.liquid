<section class="section">
  <div class="container">
    <h1 style="font-size:var(--text-h2);margin-bottom:var(--space-12);">{{ blog.title }}</h1>
    {%- paginate blog.articles by section.settings.posts_per_page -%}
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:var(--space-8);">
        {%- for article in blog.articles -%}
          <article>
            {%- if article.image -%}
              <a href="{{ article.url }}" style="display:block;aspect-ratio:3/2;overflow:hidden;margin-bottom:var(--space-4);">
                <img src="{{ article.image | image_url: width: 600 }}" alt="{{ article.image.alt | default: article.title }}" style="width:100%;height:100%;object-fit:cover;transition:transform 0.5s;" loading="lazy" width="600" height="400">
              </a>
            {%- endif -%}
            <p style="font-size:var(--text-xs);font-weight:var(--weight-bold);letter-spacing:var(--tracking-widest);text-transform:uppercase;color:var(--color-text-muted);margin-bottom:var(--space-2);">{{ article.published_at | date: '%B %d, %Y' }}</p>
            <h2 style="font-size:var(--text-h5);margin-bottom:var(--space-3);"><a href="{{ article.url }}" style="color:var(--color-heading);">{{ article.title }}</a></h2>
            <p style="font-size:var(--text-sm);color:var(--color-text-muted);margin-bottom:var(--space-4);">{{ article.excerpt_or_content | strip_html | truncate: 120 }}</p>
            <a href="{{ article.url }}" style="font-size:var(--text-sm);font-weight:var(--weight-bold);letter-spacing:var(--tracking-wider);text-transform:uppercase;border-bottom:1px solid var(--color-heading);">Read More</a>
          </article>
        {%- endfor -%}
      </div>
      {%- render 'pagination', paginate: paginate -%}
    {%- endpaginate -%}
  </div>
</section>

{% schema %}
{
  "name": "Blog Posts",
  "settings": [
    { "type": "range", "id": "posts_per_page", "label": "Posts per page", "min": 3, "max": 12, "step": 3, "default": 9 }
  ],
  "presets": [{ "name": "Blog Posts" }]
}
{% endschema %}
