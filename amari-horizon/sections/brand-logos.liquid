<section class="brand-logos section--sm">
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <h2 class="brand-logos__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    <div class="brand-logos__grid">
      {%- for block in section.blocks -%}
        {%- if block.settings.image != blank -%}
          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" class="brand-logos__item" aria-label="{{ block.settings.image.alt }}" {{ block.shopify_attributes }}>
              <img src="{{ block.settings.image | image_url: width: 200 }}" alt="{{ block.settings.image.alt }}" loading="lazy" width="200" height="50" style="max-height:50px;width:auto;object-fit:contain;">
            </a>
          {%- else -%}
            <div class="brand-logos__item" {{ block.shopify_attributes }}>
              <img src="{{ block.settings.image | image_url: width: 200 }}" alt="{{ block.settings.image.alt }}" loading="lazy" width="200" height="50" style="max-height:50px;width:auto;object-fit:contain;">
            </div>
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brand Logos",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Our Brands" }
  ],
  "blocks": [{
    "type": "logo",
    "name": "Brand Logo",
    "settings": [
      { "type": "image_picker", "id": "image", "label": "Logo image" },
      { "type": "url", "id": "link", "label": "Link" }
    ]
  }],
  "presets": [{ "name": "Brand Logos", "blocks": [{"type":"logo"},{"type":"logo"},{"type":"logo"},{"type":"logo"},{"type":"logo"}] }]
}
{% endschema %}
