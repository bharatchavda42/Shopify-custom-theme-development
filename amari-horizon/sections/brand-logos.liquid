{% comment %} Section: Brand Logos — Amari Horizon {% endcomment %}

{{ 'section-brand-logos.css' | asset_url | stylesheet_tag }}

<section
  class="brand-logos"
  id="shopify-section-{{ section.id }}"
  style="
    --bl-padding-top: {{ section.settings.padding_top }}px;
    --bl-padding-bottom: {{ section.settings.padding_bottom }}px;
    --bl-strip-bg: {{ section.settings.strip_bg }};
    --bl-logo-height: {{ section.settings.logo_height }}px;
    --bl-gap: {{ section.settings.logo_gap }}px;
  "
>
  <div class="page-width brand-logos__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="brand-logos__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="brand-logos__strip">
      {%- if section.settings.scrolling -%}
        <div class="brand-logos__track" aria-label="{{ section.settings.heading }}">
          {%- for i in (1..2) -%}
            {%- for block in section.blocks -%}
              {%- case block.type -%}
                {%- when 'logo' -%}
                  <div class="brand-logos__item" {{ block.shopify_attributes }}>
                    {%- if block.settings.logo != blank -%}
                      {{
                        block.settings.logo
                        | image_url: height: 60
                        | image_tag:
                          class: 'brand-logos__logo',
                          loading: 'lazy',
                          alt: block.settings.brand_name
                      }}
                    {%- else -%}
                      <span class="brand-logos__logo-text">{{ block.settings.brand_name | default: 'Brand' }}</span>
                    {%- endif -%}
                  </div>
              {%- endcase -%}
            {%- endfor -%}
          {%- endfor -%}
        </div>
      {%- else -%}
        <div class="brand-logos__grid">
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when 'logo' -%}
                <div class="brand-logos__item" {{ block.shopify_attributes }}>
                  {%- if block.settings.logo != blank -%}
                    {{
                      block.settings.logo
                      | image_url: height: 60
                      | image_tag:
                        class: 'brand-logos__logo',
                        loading: 'lazy',
                        alt: block.settings.brand_name
                    }}
                  {%- else -%}
                    <span class="brand-logos__logo-text">{{ block.settings.brand_name | default: 'Brand' }}</span>
                  {%- endif -%}
                </div>
            {%- endcase -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brand Logos",
  "tag": "section",
  "class": "section-brand-logos",
  "settings": [
    { "type": "text", "id": "heading", "label": "Section heading", "default": "Our Brands" },
    { "type": "color", "id": "strip_bg", "label": "Logo strip background", "default": "#b5d0e1" },
    { "type": "range", "id": "logo_height", "min": 24, "max": 80, "step": 4, "unit": "px", "label": "Logo height", "default": 50 },
    { "type": "range", "id": "logo_gap", "min": 40, "max": 200, "step": 8, "unit": "px", "label": "Gap between logos", "default": 100 },
    { "type": "checkbox", "id": "scrolling", "label": "Auto-scroll logos", "default": false },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 8, "unit": "px", "label": "Padding top", "default": 60 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 8, "unit": "px", "label": "Padding bottom", "default": 60 }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Brand Logo",
      "settings": [
        { "type": "image_picker", "id": "logo", "label": "Brand logo" },
        { "type": "text", "id": "brand_name", "label": "Brand name (alt text)", "default": "Brand" },
        { "type": "url", "id": "link", "label": "Brand link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand Logos",
      "settings": {
        "heading": "Our Brands",
        "strip_bg": "#b5d0e1",
        "logo_height": 50,
        "logo_gap": 100,
        "scrolling": false,
        "padding_top": 60,
        "padding_bottom": 60
      },
      "blocks": [
        { "type": "logo", "settings": { "brand_name": "Gucci" } },
        { "type": "logo", "settings": { "brand_name": "Louis Vuitton" } },
        { "type": "logo", "settings": { "brand_name": "Chanel" } },
        { "type": "logo", "settings": { "brand_name": "Nike" } },
        { "type": "logo", "settings": { "brand_name": "Dior" } },
        { "type": "logo", "settings": { "brand_name": "Prada" } }
      ]
    }
  ]
}
{% endschema %}
