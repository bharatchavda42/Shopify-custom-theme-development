{% comment %} Section: Hero Banner — Amari Horizon {% endcomment %}

{%- liquid
  assign hero_heading   = section.settings.heading
  assign hero_label     = section.settings.label
  assign btn_label      = section.settings.button_label
  assign btn_url        = section.settings.button_url
  assign show_marquee   = section.settings.show_marquee
  assign marquee1_text  = section.settings.marquee1_text
  assign marquee2_text  = section.settings.marquee2_text
-%}

{{ 'section-hero-banner.css' | asset_url | stylesheet_tag }}

<section
  class="hero-banner"
  id="shopify-section-{{ section.id }}"
  style="
    --hero-heading-size: {{ section.settings.heading_size }}px;
    --hero-label-size: {{ section.settings.label_size }}px;
    --hero-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --hero-overlay-color: {{ section.settings.overlay_color }};
    --hero-min-height: {{ section.settings.min_height }}px;
  "
>
  <div class="hero-banner__media">
    {%- if section.settings.image != blank -%}
      {{
        section.settings.image
        | image_url: width: 1920
        | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          class: 'hero-banner__image',
          widths: '750,1100,1440,1920',
          sizes: '100vw'
      }}
    {%- else -%}
      <div class="hero-banner__placeholder">{{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}</div>
    {%- endif -%}
    <div class="hero-banner__overlay"></div>
  </div>

  <div class="hero-banner__content">
    {%- if hero_label != blank -%}
      <p class="hero-banner__label">{{ hero_label }}</p>
    {%- endif -%}

    {%- if hero_heading != blank -%}
      <h1 class="hero-banner__heading">{{ hero_heading }}</h1>
    {%- endif -%}

    {%- if btn_label != blank -%}
      <a
        href="{{ btn_url | default: '/collections/all' }}"
        class="hero-banner__btn button"
      >{{ btn_label }}</a>
    {%- endif -%}
  </div>

  {%- if show_marquee -%}
    <div class="hero-banner__marquee-wrap" aria-hidden="true">
      <div class="hero-banner__marquee hero-banner__marquee--1">
        <div class="hero-banner__marquee-track">
          {%- for i in (1..6) -%}
            <span class="hero-banner__marquee-item">{{ marquee1_text }}</span>
            <span class="hero-banner__marquee-sep">✦</span>
          {%- endfor -%}
        </div>
      </div>
      <div class="hero-banner__marquee hero-banner__marquee--2">
        <div class="hero-banner__marquee-track">
          {%- for i in (1..6) -%}
            <span class="hero-banner__marquee-item">{{ marquee2_text }}</span>
            <span class="hero-banner__marquee-sep">✦</span>
          {%- endfor -%}
        </div>
      </div>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "section-hero",
  "settings": [
    { "type": "header", "content": "Image" },
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "range", "id": "min_height", "min": 400, "max": 1200, "step": 40, "unit": "px", "label": "Minimum height", "default": 900 },
    { "type": "header", "content": "Overlay" },
    { "type": "color", "id": "overlay_color", "label": "Overlay color", "default": "#000000" },
    { "type": "range", "id": "overlay_opacity", "min": 0, "max": 80, "step": 5, "unit": "%", "label": "Overlay opacity", "default": 30 },
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "label", "label": "Label text", "default": "FASHION & STYLE" },
    { "type": "text", "id": "heading", "label": "Hero heading", "default": "LUXURIOUS" },
    { "type": "range", "id": "heading_size", "min": 60, "max": 300, "step": 10, "unit": "px", "label": "Heading size (desktop)", "default": 220 },
    { "type": "range", "id": "label_size", "min": 24, "max": 80, "step": 4, "unit": "px", "label": "Label size", "default": 48 },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop Now" },
    { "type": "url", "id": "button_url", "label": "Button link" },
    { "type": "header", "content": "Marquee Strips" },
    { "type": "checkbox", "id": "show_marquee", "label": "Show marquee strips", "default": true },
    { "type": "text", "id": "marquee1_text", "label": "Strip 1 text", "default": "Get Up To 40% Off" },
    { "type": "color", "id": "marquee1_bg", "label": "Strip 1 background", "default": "#b5d0e1" },
    { "type": "text", "id": "marquee2_text", "label": "Strip 2 text", "default": "Get Up To 40% Off" },
    { "type": "color", "id": "marquee2_bg", "label": "Strip 2 background", "default": "#fff374" }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "settings": {
        "label": "FASHION & STYLE",
        "heading": "LUXURIOUS",
        "heading_size": 220,
        "label_size": 48,
        "overlay_opacity": 30,
        "show_marquee": true,
        "marquee1_text": "Get Up To 40% Off",
        "marquee1_bg": "#b5d0e1",
        "marquee2_text": "Get Up To 40% Off",
        "marquee2_bg": "#fff374",
        "button_label": "Shop Now"
      }
    }
  ]
}
{% endschema %}
