<div id="ProductRecommendations" data-product-id="{{ product.id }}" data-limit="{{ section.settings.products_to_show }}" data-intent="{{ section.settings.intent }}">
  <div class="product-recommendations__inner" id="ProductRecommendationsInner">
    <!-- Loaded via JS -->
  </div>
</div>

<script>
  (function(){
    var section = document.getElementById('ProductRecommendations');
    if (!section) return;
    var productId = section.dataset.productId;
    var limit = section.dataset.limit;
    var intent = section.dataset.intent;
    var url = '/recommendations/products.json?product_id=' + productId + '&limit=' + limit + '&intent=' + intent;
    fetch(url)
      .then(function(r){ return r.json(); })
      .then(function(data){
        if (!data.products || !data.products.length) return;
        var html = '<section class="section"><div class="container">';
        html += '<h2 class="section-header__title" style="margin-bottom:var(--space-12);">{{ section.settings.heading | escape }}</h2>';
        html += '<div class="product-grid">';
        data.products.forEach(function(p){
          var price = p.price_min ? (p.price_min / 100).toFixed(2) : '0.00';
          var img = p.featured_image ? p.featured_image : '';
          html += '<div class="product-card">';
          html += '<a href="' + p.url + '" class="product-card__media" style="display:block;">';
          if(img) html += '<img src="' + img + '&width=600" alt="' + p.title + '" class="product-card__image" loading="lazy" width="600" height="600">';
          html += '</a>';
          html += '<div class="product-card__info">';
          if(p.vendor) html += '<span class="product-card__vendor">' + p.vendor + '</span>';
          html += '<a href="' + p.url + '" class="product-card__title">' + p.title + '</a>';
          html += '<div class="price"><span class="price__current">$' + price + '</span></div>';
          html += '</div></div>';
        });
        html += '</div></div></section>';
        document.getElementById('ProductRecommendationsInner').innerHTML = html;
      });
  })();
</script>

{% schema %}
{
  "name": "Product Recommendations",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "You May Also Like" },
    { "type": "range", "id": "products_to_show", "label": "Products to show", "min": 2, "max": 8, "step": 1, "default": 4 },
    { "type": "select", "id": "intent", "label": "Recommendation intent", "options": [{"value":"related","label":"Related"},{"value":"complementary","label":"Complementary"}], "default": "related" }
  ],
  "presets": [{ "name": "Product Recommendations" }]
}
{% endschema %}
