{% comment %} Section: Footer — Amari Horizon {% endcomment %}

{{ 'section-footer.css' | asset_url | stylesheet_tag }}

<footer
  class="site-footer"
  id="shopify-section-{{ section.id }}"
  role="contentinfo"
  style="
    --footer-bg: {{ section.settings.footer_bg }};
    --footer-text: {{ section.settings.footer_text_color }};
    --footer-border: {{ section.settings.footer_border_color }};
  "
>

  {%- if section.settings.show_instagram -%}
    <div class="site-footer__instagram">
      <div class="page-width site-footer__instagram-inner">
        {%- if section.settings.instagram_heading != blank -%}
          <h2 class="site-footer__instagram-heading">{{ section.settings.instagram_heading }}</h2>
        {%- endif -%}
        {%- if section.settings.instagram_images_count > 0 -%}
          <div class="site-footer__instagram-grid">
            {%- for block in section.blocks -%}
              {%- case block.type -%}
                {%- when 'instagram_image' -%}
                  <div class="site-footer__instagram-item" {{ block.shopify_attributes }}>
                    {%- if block.settings.image != blank -%}
                      <a href="{{ section.settings.instagram_url | default: '#' }}" target="_blank" rel="noopener" class="site-footer__instagram-link">
                        {{
                          block.settings.image
                          | image_url: width: 400
                          | image_tag:
                            class: 'site-footer__instagram-img',
                            loading: 'lazy',
                            widths: '300,400',
                            sizes: '(max-width: 749px) 50vw, 16vw'
                        }}
                        <div class="site-footer__instagram-overlay">
                          <svg width="42" height="42" viewBox="0 0 42 42" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <rect x="5" y="5" width="32" height="32" rx="8" stroke="white" stroke-width="1.5"/>
                            <circle cx="21" cy="21" r="7" stroke="white" stroke-width="1.5"/>
                            <circle cx="30" cy="12" r="2" fill="white"/>
                          </svg>
                        </div>
                      </a>
                    {%- endif -%}
                  </div>
              {%- endcase -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

  <div class="site-footer__main">
    <div class="page-width site-footer__main-inner">

      <div class="site-footer__col site-footer__col--brand">
        {%- if section.settings.footer_logo != blank -%}
          <a href="{{ routes.root_url }}" class="site-footer__logo-link" aria-label="{{ shop.name }}">
            {{
              section.settings.footer_logo
              | image_url: width: 150
              | image_tag:
                class: 'site-footer__logo',
                loading: 'lazy',
                alt: shop.name
            }}
          </a>
        {%- else -%}
          <a href="{{ routes.root_url }}" class="site-footer__logo-link site-footer__logo-text" aria-label="{{ shop.name }}">
            {{ shop.name }}
          </a>
        {%- endif -%}
        {%- if section.settings.brand_description != blank -%}
          <p class="site-footer__brand-desc">{{ section.settings.brand_description }}</p>
        {%- endif -%}
      </div>

      {%- for i in (1..3) -%}
        {%- liquid
          assign col_heading = 'footer_col_' | append: i | append: '_heading'
          assign col_menu    = 'footer_col_' | append: i | append: '_menu'
        -%}
        {%- if section.settings[col_heading] != blank -%}
          <div class="site-footer__col">
            <h3 class="site-footer__col-heading">{{ section.settings[col_heading] }}</h3>
            {%- if section.settings[col_menu] != blank -%}
              <ul class="site-footer__nav-list" role="list">
                {%- for link in linklists[section.settings[col_menu]].links -%}
                  <li><a href="{{ link.url }}" class="site-footer__nav-link">{{ link.title }}</a></li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}

      {%- if section.settings.show_contact -%}
        <div class="site-footer__col">
          <h3 class="site-footer__col-heading">{{ section.settings.contact_heading | default: 'Contact Info' }}</h3>
          {%- if section.settings.contact_address != blank -%}
            <p class="site-footer__contact-item">
              <svg width="14" height="20" viewBox="0 0 14 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M7 0C3.13 0 0 3.13 0 7C0 12.25 7 20 7 20C7 20 14 12.25 14 7C14 3.13 10.87 0 7 0ZM7 9.5C5.62 9.5 4.5 8.38 4.5 7C4.5 5.62 5.62 4.5 7 4.5C8.38 4.5 9.5 5.62 9.5 7C9.5 8.38 8.38 9.5 7 9.5Z" fill="currentColor" opacity="0.7"/>
              </svg>
              {{ section.settings.contact_address }}
            </p>
          {%- endif -%}
          {%- if section.settings.contact_email != blank -%}
            <p class="site-footer__contact-item">
              <svg width="20" height="16" viewBox="0 0 20 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="1" y="1" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.5" opacity="0.7"/>
                <path d="M1 4L10 9.5L19 4" stroke="currentColor" stroke-width="1.5" opacity="0.7"/>
              </svg>
              <a href="mailto:{{ section.settings.contact_email }}" class="site-footer__contact-link">{{ section.settings.contact_email }}</a>
            </p>
          {%- endif -%}
        </div>
      {%- endif -%}

    </div>
  </div>

  <div class="site-footer__bottom">
    <div class="page-width site-footer__bottom-inner">
      <p class="site-footer__copyright">
        {{ section.settings.copyright_text | default: shop.name }}
        &copy; {{ 'now' | date: '%Y' }}. All rights reserved.
      </p>

      <div class="site-footer__socials">
        {%- if settings.social_facebook != blank -%}
          <a href="{{ settings.social_facebook }}" class="site-footer__social-link" target="_blank" rel="noopener" aria-label="Facebook">
            <svg width="10" height="18" viewBox="0 0 10 18" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M6.5 6.5V4.5C6.5 3.67 7.17 3 8 3H9V0H7C4.79 0 3 1.79 3 4V6.5H0V9.5H3V18H6.5V9.5H9L10 6.5H6.5Z" fill="currentColor"/>
            </svg>
          </a>
        {%- endif -%}
        {%- if settings.social_twitter != blank -%}
          <a href="{{ settings.social_twitter }}" class="site-footer__social-link" target="_blank" rel="noopener" aria-label="Twitter / X">
            <svg width="18" height="16" viewBox="0 0 18 16" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M18 2C17.3 2.35 16.5 2.6 15.7 2.7C16.5 2.2 17.1 1.4 17.4 0.5C16.6 1 15.8 1.3 14.9 1.5C14.1 0.6 13 0 11.8 0C9.5 0 7.6 1.9 7.6 4.2C7.6 4.55 7.65 4.9 7.7 5.2C5 5.05 2.65 3.3 1.1 0.85C0.75 1.4 0.55 2.1 0.55 2.8C0.55 4.15 1.2 5.35 2.25 6.05C1.6 6.05 0.95 5.85 0.4 5.55V5.6C0.4 7.65 1.85 9.3 3.8 9.7C3.45 9.8 3.05 9.85 2.65 9.85C2.35 9.85 2.1 9.8 1.8 9.75C2.35 11.45 3.95 12.7 5.8 12.75C4.35 13.9 2.5 14.6 0.55 14.6C0.2 14.6 -0.1 14.55 -0.4 14.5C1.45 15.65 3.6 16.3 5.9 16.3C11.75 16.3 14.95 10.95 14.95 6.3C14.95 6.15 14.95 6 14.9 5.85C15.7 5.35 16.35 4.7 16.95 3.95L18 2Z" fill="currentColor"/>
            </svg>
          </a>
        {%- endif -%}
        {%- if settings.social_instagram != blank -%}
          <a href="{{ settings.social_instagram }}" class="site-footer__social-link" target="_blank" rel="noopener" aria-label="Instagram">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="1" y="1" width="16" height="16" rx="5" stroke="currentColor" stroke-width="1.5"/>
              <circle cx="9" cy="9" r="4" stroke="currentColor" stroke-width="1.5"/>
              <circle cx="14" cy="4" r="1" fill="currentColor"/>
            </svg>
          </a>
        {%- endif -%}
      </div>

      {%- if section.settings.show_payment_icons -%}
        <div class="site-footer__payment">
          {%- for type in shop.enabled_payment_types -%}
            {{ type | payment_type_svg_tag: class: 'site-footer__payment-icon' }}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>

</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "header", "content": "Instagram gallery" },
    { "type": "checkbox", "id": "show_instagram", "label": "Show Instagram gallery", "default": false },
    { "type": "text", "id": "instagram_heading", "label": "Instagram heading", "default": "Follow Us On Instagram" },
    { "type": "url", "id": "instagram_url", "label": "Instagram URL" },
    { "type": "range", "id": "instagram_images_count", "min": 0, "max": 8, "step": 1, "label": "Images to show", "default": 6 },
    { "type": "header", "content": "Brand column" },
    { "type": "image_picker", "id": "footer_logo", "label": "Footer logo" },
    { "type": "textarea", "id": "brand_description", "label": "Brand description", "default": "Skin care products that go beyond the surface, nurturing your skin at its core." },
    { "type": "header", "content": "Link columns" },
    { "type": "text", "id": "footer_col_1_heading", "label": "Column 1 heading", "default": "Quick Links" },
    { "type": "link_list", "id": "footer_col_1_menu", "label": "Column 1 menu", "default": "footer" },
    { "type": "text", "id": "footer_col_2_heading", "label": "Column 2 heading", "default": "Need Help" },
    { "type": "link_list", "id": "footer_col_2_menu", "label": "Column 2 menu" },
    { "type": "text", "id": "footer_col_3_heading", "label": "Column 3 heading" },
    { "type": "link_list", "id": "footer_col_3_menu", "label": "Column 3 menu" },
    { "type": "header", "content": "Contact info" },
    { "type": "checkbox", "id": "show_contact", "label": "Show contact info", "default": true },
    { "type": "text", "id": "contact_heading", "label": "Contact heading", "default": "Contact Info" },
    { "type": "text", "id": "contact_address", "label": "Address", "default": "6847 Stirling Rd, Davie, Florida, US" },
    { "type": "text", "id": "contact_email", "label": "Email", "default": "info@amari.com" },
    { "type": "header", "content": "Bottom bar" },
    { "type": "text", "id": "copyright_text", "label": "Copyright name", "default": "Copyright © Amari 2026" },
    { "type": "checkbox", "id": "show_payment_icons", "label": "Show payment icons", "default": true },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "footer_bg", "label": "Footer background", "default": "#4A4A4A" },
    { "type": "color", "id": "footer_text_color", "label": "Text color", "default": "#FFFFFF" },
    { "type": "color", "id": "footer_border_color", "label": "Border color", "default": "#5a5a5a" }
  ],
  "blocks": [
    {
      "type": "instagram_image",
      "name": "Instagram Photo",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Photo" }
      ]
    }
  ]
}
{% endschema %}
