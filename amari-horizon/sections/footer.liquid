<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="site-footer__top">
      <!-- Brand column -->
      <div class="footer-col footer-brand">
        {%- if section.settings.logo != blank -%}
          <img src="{{ section.settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}" class="footer-brand__logo" width="160" height="40" loading="lazy">
        {%- else -%}
          <div class="footer-brand__logo" style="font-family:var(--font-heading);font-size:var(--text-h5);font-weight:var(--weight-bold);letter-spacing:var(--tracking-widest);text-transform:uppercase;color:#FFFFFF;margin-bottom:var(--space-5);">{{ shop.name }}</div>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <p class="footer-brand__desc">{{ section.settings.description }}</p>
        {%- endif -%}
        <!-- Social -->
        <div class="footer-social">
          {%- if settings.social_instagram != blank -%}
            <a href="{{ settings.social_instagram }}" class="footer-social__link" target="_blank" rel="noopener" aria-label="Instagram">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_facebook != blank -%}
            <a href="{{ settings.social_facebook }}" class="footer-social__link" target="_blank" rel="noopener" aria-label="Facebook">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_tiktok != blank -%}
            <a href="{{ settings.social_tiktok }}" class="footer-social__link" target="_blank" rel="noopener" aria-label="TikTok">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.97a8.27 8.27 0 004.84 1.54V7.07a4.85 4.85 0 01-1.07-.38z"/></svg>
            </a>
          {%- endif -%}
        </div>
      </div>

      <!-- Link columns -->
      {%- for block in section.blocks -%}
        {%- if block.type == 'link_list' -%}
          <div class="footer-col" {{ block.shopify_attributes }}>
            <h3 class="footer-col__heading">{{ block.settings.heading }}</h3>
            <ul class="footer-col__links">
              {%- for link in linklists[block.settings.menu].links -%}
                <li><a href="{{ link.url }}" class="footer-col__link">{{ link.title }}</a></li>
              {%- endfor -%}
            </ul>
          </div>
        {%- elsif block.type == 'text' -%}
          <div class="footer-col" {{ block.shopify_attributes }}>
            <h3 class="footer-col__heading">{{ block.settings.heading }}</h3>
            <div style="font-size:var(--text-base);color:#AAAAAA;line-height:var(--leading-relaxed);">{{ block.settings.text }}</div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="site-footer__bottom">
      <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
      <div class="site-footer__payment">
        <span style="font-size:var(--text-xs);margin-right:var(--space-2);">Secure payments:</span>
        <svg width="38" height="24" viewBox="0 0 38 24" fill="none"><rect width="38" height="24" rx="4" fill="#1A1F71"/><path d="M13.5 7.5h11v9h-11z" fill="#FF5F00"/><path d="M14.5 12a5.5 5.5 0 015.5-5.5 5.5 5.5 0 000 11A5.5 5.5 0 0114.5 12z" fill="#EB001B"/><path d="M23.5 12a5.5 5.5 0 01-5.5 5.5 5.5 5.5 0 000-11A5.5 5.5 0 0123.5 12z" fill="#F79E1B"/></svg>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Footer logo" },
    { "type": "textarea", "id": "description", "label": "Brand description" }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Link Column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Column heading", "default": "Quick Links" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    },
    {
      "type": "text",
      "name": "Text Column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Column heading", "default": "Contact" },
        { "type": "richtext", "id": "text", "label": "Content" }
      ]
    }
  ],
  "presets": [{
    "name": "Footer",
    "blocks": [
      { "type": "link_list", "settings": { "heading": "Shop", "menu": "main-menu" } },
      { "type": "link_list", "settings": { "heading": "Help", "menu": "footer" } },
      { "type": "text", "settings": { "heading": "Contact Us" } }
    ]
  }]
}
{% endschema %}
