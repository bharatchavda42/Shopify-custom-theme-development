<section class="section" style="background-color:{{ section.settings.bg_color }};">
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <h2 class="section-header__title" style="text-align:center;margin-bottom:var(--space-12);">{{ section.settings.heading }}</h2>
    {%- endif -%}
    <div style="display:grid;grid-template-columns:repeat({{ section.settings.columns }},1fr);gap:var(--space-8);text-align:center;">
      {%- for block in section.blocks -%}
        <div class="icon-feature" {{ block.shopify_attributes }}>
          {%- if block.settings.icon != blank -%}
            <div style="font-size:48px;margin-bottom:var(--space-4);">{{ block.settings.icon }}</div>
          {%- elsif block.settings.image != blank -%}
            <div style="margin-bottom:var(--space-4);display:flex;justify-content:center;">
              <img src="{{ block.settings.image | image_url: width: 80 }}" alt="{{ block.settings.heading }}" width="64" height="64" style="object-fit:contain;">
            </div>
          {%- endif -%}
          <h3 style="font-size:var(--text-h6);margin-bottom:var(--space-3);">{{ block.settings.heading }}</h3>
          {%- if block.settings.text != blank -%}
            <p style="font-size:var(--text-sm);color:var(--color-text-muted);line-height:var(--leading-relaxed);">{{ block.settings.text }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Icon Features",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "range", "id": "columns", "label": "Columns", "min": 2, "max": 5, "step": 1, "default": 4 },
    { "type": "color", "id": "bg_color", "label": "Background color", "default": "#FFFFFF" }
  ],
  "blocks": [{
    "type": "feature",
    "name": "Feature",
    "settings": [
      { "type": "text", "id": "icon", "label": "Icon emoji" },
      { "type": "image_picker", "id": "image", "label": "Icon image (alternative)" },
      { "type": "text", "id": "heading", "label": "Heading", "default": "Free Shipping" },
      { "type": "textarea", "id": "text", "label": "Description", "default": "On all orders over $100" }
    ]
  }],
  "presets": [{
    "name": "Icon Features",
    "blocks": [
      { "type": "feature", "settings": { "icon": "🚚", "heading": "Free Shipping", "text": "On orders over $100" } },
      { "type": "feature", "settings": { "icon": "↩️", "heading": "Easy Returns", "text": "30-day hassle-free returns" } },
      { "type": "feature", "settings": { "icon": "🔒", "heading": "Secure Payment", "text": "100% secure checkout" } },
      { "type": "feature", "settings": { "icon": "💬", "heading": "24/7 Support", "text": "We're here to help" } }
    ]
  }]
}
{% endschema %}
