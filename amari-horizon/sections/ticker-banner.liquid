{% comment %} Section: Ticker Banner — Amari Horizon {% endcomment %}

{{ 'section-ticker-banner.css' | asset_url | stylesheet_tag }}

<section
  class="ticker-banner"
  id="shopify-section-{{ section.id }}"
  style="
    --ticker-bg: {{ section.settings.bg_color }};
    --ticker-color: {{ section.settings.text_color }};
    --ticker-font-size: {{ section.settings.font_size }}px;
    --ticker-speed: {{ section.settings.speed }}s;
  "
>
  <div class="ticker-banner__track" aria-hidden="true">
    {%- for i in (1..3) -%}
      {%- for block in section.blocks -%}
        <span class="ticker-banner__item" {{ block.shopify_attributes }}>
          {{ block.settings.text }}
          {%- if block.settings.show_spark %}<span class="ticker-banner__spark">✦</span>{%- endif -%}
        </span>
      {%- endfor -%}
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Ticker Banner",
  "tag": "section",
  "class": "section-ticker",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background color", "default": "#1A1A1A" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#FFFFFF" },
    { "type": "range", "id": "font_size", "min": 12, "max": 24, "step": 1, "unit": "px", "label": "Font size", "default": 14 },
    { "type": "range", "id": "speed", "min": 10, "max": 60, "step": 5, "unit": "s", "label": "Scroll speed", "default": 30 }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Ticker item",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Free Shipping on Orders $100+" },
        { "type": "checkbox", "id": "show_spark", "label": "Show separator spark", "default": true }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ticker Banner",
      "settings": {
        "bg_color": "#1A1A1A",
        "text_color": "#FFFFFF",
        "font_size": 14,
        "speed": 30
      },
      "blocks": [
        { "type": "item", "settings": { "text": "Free Shipping on Orders $100+", "show_spark": true } },
        { "type": "item", "settings": { "text": "New Arrivals Every Week", "show_spark": true } },
        { "type": "item", "settings": { "text": "Get Up To 40% Off Sale Items", "show_spark": true } }
      ]
    }
  ]
}
{% endschema %}
