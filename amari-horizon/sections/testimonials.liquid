<section class="testimonials section" style="background-color:{{ section.settings.bg_color }};">
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <h2 class="section-header__title" style="text-align:center;margin-bottom:var(--space-12);">{{ section.settings.heading }}</h2>
    {%- endif -%}
    <div class="testimonials__grid">
      {%- for block in section.blocks -%}
        <div class="testimonial-card" {{ block.shopify_attributes }}>
          <div class="testimonial-card__stars">
            {%- for i in (1..block.settings.rating) -%}★{%- endfor -%}
          </div>
          <p class="testimonial-card__text">{{ block.settings.review }}</p>
          <div class="testimonial-card__author">
            {%- if block.settings.avatar != blank -%}
              <img src="{{ block.settings.avatar | image_url: width: 96 }}" alt="{{ block.settings.name }}" class="testimonial-card__avatar" loading="lazy" width="48" height="48">
            {%- endif -%}
            <div>
              <div class="testimonial-card__name">{{ block.settings.name }}</div>
              {%- if block.settings.role != blank -%}
                <div class="testimonial-card__role">{{ block.settings.role }}</div>
              {%- endif -%}
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "What Our Customers Say" },
    { "type": "color", "id": "bg_color", "label": "Background color", "default": "#F7F7F7" }
  ],
  "blocks": [{
    "type": "review",
    "name": "Review",
    "settings": [
      { "type": "range", "id": "rating", "label": "Rating", "min": 1, "max": 5, "step": 1, "default": 5 },
      { "type": "textarea", "id": "review", "label": "Review text", "default": "Absolutely love the quality! The fit is perfect and the fabric is incredibly soft." },
      { "type": "image_picker", "id": "avatar", "label": "Avatar" },
      { "type": "text", "id": "name", "label": "Reviewer name", "default": "Sarah M." },
      { "type": "text", "id": "role", "label": "Role / location", "default": "Verified Buyer" }
    ]
  }],
  "presets": [{
    "name": "Testimonials",
    "blocks": [
      { "type": "review", "settings": { "name": "Sarah M.", "role": "Verified Buyer" } },
      { "type": "review", "settings": { "name": "James K.", "role": "Verified Buyer" } },
      { "type": "review", "settings": { "name": "Priya R.", "role": "Verified Buyer" } }
    ]
  }]
}
{% endschema %}
