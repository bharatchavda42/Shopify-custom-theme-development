<div style="height:{{ section.settings.height_desktop }}px;" class="spacer-desktop"></div>
<style>
  @media(max-width:767px){ .spacer-desktop{ height:{{ section.settings.height_mobile }}px !important; } }
</style>
{% schema %}
{
  "name": "Spacer",
  "settings": [
    { "type": "range", "id": "height_desktop", "label": "Height (desktop)", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "height_mobile",  "label": "Height (mobile)",  "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 }
  ],
  "presets": [{ "name": "Spacer" }]
}
{% endschema %}
