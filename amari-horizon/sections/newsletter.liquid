{% comment %} Section: Newsletter — Amari Horizon {% endcomment %}

{{ 'section-newsletter.css' | asset_url | stylesheet_tag }}

<section
  class="newsletter-section"
  id="shopify-section-{{ section.id }}"
  style="
    --nl-bg: {{ section.settings.bg_color }};
    --nl-text-color: {{ section.settings.text_color }};
    --nl-btn-bg: {{ section.settings.button_bg }};
    --nl-btn-color: {{ section.settings.button_text_color }};
    --nl-padding-top: {{ section.settings.padding_top }}px;
    --nl-padding-bottom: {{ section.settings.padding_bottom }}px;
    --nl-radius: {{ section.settings.input_radius }}px;
  "
>
  <div class="page-width newsletter-section__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="newsletter-section__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subtext != blank -%}
      <p class="newsletter-section__subtext">{{ section.settings.subtext }}</p>
    {%- endif -%}

    {%- form 'customer', id: 'ContactForm', class: 'newsletter-section__form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <div class="newsletter-section__field-wrap">
        <input
          type="email"
          name="contact[email]"
          id="newsletter-email-{{ section.id }}"
          class="newsletter-section__input"
          placeholder="{{ section.settings.placeholder | default: 'Enter your email' }}"
          aria-label="{{ section.settings.placeholder | default: 'Enter your email' }}"
          required
          autocomplete="email"
        >
        <button type="submit" class="newsletter-section__btn">
          {{ section.settings.button_label | default: 'Subscribe' }}
        </button>
      </div>
      {%- if form.posted_successfully? -%}
        <p class="newsletter-section__success">{{ 'newsletter.success' | t }}</p>
      {%- endif -%}
      {%- if form.errors -%}
        <p class="newsletter-section__error">{{ form.errors.translated_fields.email | capitalize }}: {{ form.errors.messages.email }}</p>
      {%- endif -%}
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "class": "section-newsletter",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Join Our Community" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Subscribe for exclusive offers, new arrivals, and style inspiration." },
    { "type": "text", "id": "placeholder", "label": "Input placeholder", "default": "Enter your email address" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Subscribe" },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_color", "label": "Background color", "default": "#F7F7F7" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#1A1A1A" },
    { "type": "color", "id": "button_bg", "label": "Button background", "default": "#1A1A1A" },
    { "type": "color", "id": "button_text_color", "label": "Button text color", "default": "#FFFFFF" },
    { "type": "range", "id": "input_radius", "min": 0, "max": 50, "step": 4, "unit": "px", "label": "Input/button radius", "default": 0 },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 8, "unit": "px", "label": "Padding top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 8, "unit": "px", "label": "Padding bottom", "default": 80 }
  ],
  "presets": [
    {
      "name": "Newsletter",
      "settings": {
        "heading": "Join Our Community",
        "subtext": "Subscribe for exclusive offers, new arrivals, and style inspiration.",
        "placeholder": "Enter your email address",
        "button_label": "Subscribe",
        "bg_color": "#F7F7F7",
        "text_color": "#1A1A1A",
        "button_bg": "#1A1A1A",
        "button_text_color": "#FFFFFF",
        "input_radius": 0,
        "padding_top": 80,
        "padding_bottom": 80
      }
    }
  ]
}
{% endschema %}
