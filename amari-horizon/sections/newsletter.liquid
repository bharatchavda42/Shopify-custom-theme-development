<section class="newsletter section" style="background-color:{{ section.settings.bg_color }};">
  <div class="container container--narrow" style="text-align:center;">
    {%- if section.settings.heading != blank -%}
      <h2 class="newsletter__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subtext != blank -%}
      <p class="newsletter__subtext">{{ section.settings.subtext }}</p>
    {%- endif -%}

    {%- form 'customer', id: 'newsletter-form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      {%- if form.posted_successfully? -%}
        <p style="color:var(--color-success);font-weight:var(--weight-bold);">{{ 'newsletter.success' | t }}</p>
      {%- else -%}
        <div class="newsletter__form">
          <input class="newsletter__input"
                 type="email"
                 name="contact[email]"
                 id="newsletter-email"
                 placeholder="{{ section.settings.placeholder }}"
                 aria-label="{{ section.settings.placeholder }}"
                 required>
          <button type="submit" class="btn btn--primary newsletter__btn">{{ section.settings.button_label }}</button>
        </div>
        {%- if form.errors -%}
          <p style="color:var(--color-error);margin-top:var(--space-3);">{{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}</p>
        {%- endif -%}
      {%- endif -%}
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Join Our Community" },
    { "type": "text", "id": "subtext", "label": "Subtext", "default": "Subscribe for exclusive offers, new arrivals, and style inspiration." },
    { "type": "text", "id": "placeholder", "label": "Input placeholder", "default": "Enter your email address" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Subscribe" },
    { "type": "color", "id": "bg_color", "label": "Background color", "default": "#F7F7F7" }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
