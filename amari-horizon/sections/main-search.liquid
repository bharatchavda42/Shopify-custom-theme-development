<section class="section">
  <div class="container">
    <h1 style="font-size:var(--text-h2);text-align:center;margin-bottom:var(--space-10);">{{ 'general.search.title' | t }}</h1>
    <div style="max-width:600px;margin:0 auto var(--space-12);">
      {%- form 'search', action: routes.search_url -%}
        <input type="hidden" name="type" value="product">
        <div class="search-form">
          <input class="search-form__input" type="search" name="q" value="{{ search.terms | escape }}" placeholder="{{ 'general.search.placeholder' | t }}" aria-label="{{ 'general.search.placeholder' | t }}">
          <button class="search-form__submit" type="submit" aria-label="{{ 'general.search.search' | t }}">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="8.5" cy="8.5" r="6.5" stroke="currentColor" stroke-width="1.5"/><path d="M13.5 13.5L18 18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </button>
        </div>
      {%- endform -%}
    </div>
    {%- if search.performed -%}
      {%- if search.results_count > 0 -%}
        <p style="margin-bottom:var(--space-8);color:var(--color-text-muted);">{{ 'general.search.results_with_count' | t: terms: search.terms, count: search.results_count }}</p>
        <div class="product-grid">
          {%- for item in search.results -%}
            {%- if item.object_type == 'product' -%}
              {%- render 'product-card', product: item -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- else -%}
        <p style="text-align:center;color:var(--color-text-muted);">{{ 'general.search.no_results' | t: terms: search.terms }}</p>
      {%- endif -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Search",
  "settings": [],
  "presets": [{ "name": "Search" }]
}
{% endschema %}
