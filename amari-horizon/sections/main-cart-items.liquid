<section class="section--sm">
  <div class="container">
    <h1 style="font-size:var(--text-h2);margin-bottom:var(--space-12);">{{ 'sections.cart.title' | t }}</h1>

    {%- if cart.item_count > 0 -%}
      {%- form 'cart', cart, id: 'CartForm' -%}
        <div style="display:grid;grid-template-columns:1fr 380px;gap:var(--space-16);">
          <div>
            <table style="width:100%;border-collapse:collapse;" id="CartItems">
              <thead>
                <tr style="border-bottom:2px solid var(--color-border);">
                  <th style="text-align:left;padding-bottom:var(--space-4);font-size:var(--text-sm);letter-spacing:var(--tracking-widest);text-transform:uppercase;">{{ 'sections.cart.headings.product' | t }}</th>
                  <th style="text-align:center;padding-bottom:var(--space-4);font-size:var(--text-sm);letter-spacing:var(--tracking-widest);text-transform:uppercase;">{{ 'sections.cart.headings.quantity' | t }}</th>
                  <th style="text-align:right;padding-bottom:var(--space-4);font-size:var(--text-sm);letter-spacing:var(--tracking-widest);text-transform:uppercase;">{{ 'sections.cart.headings.total' | t }}</th>
                </tr>
              </thead>
              <tbody>
                {%- for item in cart.items -%}
                  <tr style="border-bottom:1px solid var(--color-border);" id="CartItem-{{ item.index | plus: 1 }}">
                    <td style="padding-block:var(--space-6);">
                      <div style="display:flex;gap:var(--space-5);">
                        <a href="{{ item.url }}">
                          <img src="{{ item.image | image_url: width: 120 }}" alt="{{ item.image.alt | default: item.product.title }}" style="width:96px;height:96px;object-fit:cover;background:var(--color-bg-alt);" loading="lazy" width="96" height="96">
                        </a>
                        <div>
                          <p style="font-size:var(--text-xs);font-weight:var(--weight-bold);letter-spacing:var(--tracking-widest);text-transform:uppercase;color:var(--color-text-muted);">{{ item.vendor }}</p>
                          <a href="{{ item.url }}" style="font-weight:var(--weight-bold);color:var(--color-heading);">{{ item.product.title }}</a>
                          {%- unless item.product.has_only_default_variant -%}
                            <p style="font-size:var(--text-sm);color:var(--color-text-muted);">{{ item.variant.title }}</p>
                          {%- endunless -%}
                          <button type="button" class="cart-item__remove" data-index="{{ item.index | plus: 1 }}">{{ 'sections.cart.remove' | t }}</button>
                        </div>
                      </div>
                    </td>
                    <td style="text-align:center;padding-block:var(--space-6);">
                      {%- render 'quantity-input', item: item, input_id: 'Qty-' | append: item.index | append: 1 -%}
                    </td>
                    <td style="text-align:right;padding-block:var(--space-6);font-weight:var(--weight-bold);">
                      {{ item.final_line_price | money }}
                    </td>
                  </tr>
                {%- endfor -%}
              </tbody>
            </table>
          </div>
          <!-- Summary -->
          <div>
            <div style="border:1px solid var(--color-border);padding:var(--space-8);">
              <h2 style="font-size:var(--text-h5);margin-bottom:var(--space-6);">{{ 'sections.cart.order_summary' | t | default: 'Order Summary' }}</h2>
              <div style="display:flex;justify-content:space-between;margin-bottom:var(--space-3);">
                <span>Subtotal</span><span style="font-weight:var(--weight-bold);">{{ cart.total_price | money }}</span>
              </div>
              <p style="font-size:var(--text-sm);color:var(--color-text-muted);margin-bottom:var(--space-8);">Shipping and taxes calculated at checkout</p>
              <button type="submit" name="checkout" class="btn btn--primary btn--full btn--lg">{{ 'sections.cart.checkout' | t }}</button>
            </div>
          </div>
        </div>
      {%- endform -%}
    {%- else -%}
      <div style="text-align:center;padding:var(--space-20) 0;">
        <p style="font-size:var(--text-lg);color:var(--color-text-muted);margin-bottom:var(--space-8);">{{ 'sections.cart.empty' | t }}</p>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary">Continue Shopping</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Cart Items",
  "settings": [],
  "presets": [{ "name": "Cart Items" }]
}
{% endschema %}
