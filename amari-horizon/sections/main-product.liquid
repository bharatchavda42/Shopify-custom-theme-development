{%- liquid
  assign product = product
  assign current_variant = product.selected_or_first_available_variant
  assign media_count = product.media.size
-%}

<section class="main-product section--flush">
  <div class="container">
    {%- render 'breadcrumbs' -%}

    <div class="product-layout">
      <!-- Gallery -->
      <div class="product-gallery" id="ProductGallery">
        <div class="product-gallery__main" id="GalleryMain">
          {%- for media in product.media -%}
            <div class="product-gallery__slide{% if forloop.first %} is-active{% endif %}"
                 data-media-id="{{ media.id }}"
                 {% unless forloop.first %}style="display:none;"{% endunless %}>
              {%- if media.media_type == 'image' -%}
                <img src="{{ media | image_url: width: 800 }}"
                     srcset="{{ media | image_url: width: 400 }} 400w, {{ media | image_url: width: 800 }} 800w"
                     sizes="(max-width:767px) 100vw, 50vw"
                     alt="{{ media.alt | default: product.title }}"
                     class="product-gallery__image"
                     {% if forloop.first %}loading="eager"{% else %}loading="lazy"{% endif %}
                     width="800" height="800">
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
        {%- if media_count > 1 -%}
          <div class="product-gallery__thumbs" id="GalleryThumbs">
            {%- for media in product.media -%}
              <button class="product-gallery__thumb{% if forloop.first %} is-active{% endif %}" data-media-id="{{ media.id }}">
                <img src="{{ media | image_url: width: 120 }}" alt="{{ media.alt }}" loading="lazy" width="120" height="120">
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <!-- Info -->
      <div class="product-info">
        {%- if product.vendor != blank -%}
          <p class="product-info__vendor">{{ product.vendor }}</p>
        {%- endif -%}

        <h1 class="product-info__title">{{ product.title }}</h1>

        <div class="product-info__price" id="ProductPrice">
          {%- render 'price', product: product, use_variant: true -%}
        </div>

        {%- if product.description != blank -%}
          <div class="product-info__description">{{ product.description }}</div>
        {%- endif -%}

        {%- form 'product', product, id: 'ProductForm', class: 'product-form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
          <input type="hidden" name="id" value="{{ current_variant.id }}" id="ProductVariantId">

          {%- unless product.has_only_default_variant -%}
            <div class="product-form__options">
              {%- for option in product.options_with_values -%}
                <div class="product-option">
                  <label class="product-option__label">{{ option.name }}</label>
                  <div class="product-option__values">
                    {%- for value in option.values -%}
                      <button type="button"
                              class="variant-btn{% if option.selected_value == value %} is-selected{% endif %}"
                              data-option-index="{{ forloop.parentloop.index0 }}"
                              data-option-value="{{ value | escape }}"
                              aria-label="{{ option.name }}: {{ value }}">
                        {{ value }}
                      </button>
                    {%- endfor -%}
                  </div>
                </div>
              {%- endfor -%}
            </div>
          {%- endunless -%}

          <div class="product-form__qty">
            {%- render 'quantity-input', input_id: 'Quantity' -%}
          </div>

          <div class="product-form__atc" style="margin-top:var(--space-6);">
            <button type="submit"
                    class="btn btn--primary btn--lg btn--full"
                    id="AddToCart"
                    {% unless current_variant.available %}disabled{% endunless %}>
              {%- if current_variant.available -%}
                {{ 'products.product.add_to_cart' | t }}
              {%- else -%}
                {{ 'products.product.sold_out' | t }}
              {%- endif -%}
            </button>
          </div>
        {%- endform -%}

        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'tab' -%}
              <div class="product-tab" {{ block.shopify_attributes }}>
                <button class="product-tab__trigger">{{ block.settings.heading }}</button>
                <div class="product-tab__content">{{ block.settings.content }}</div>
              </div>
          {%- endcase -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<style>
  .product-layout { display:grid; grid-template-columns:1fr 1fr; gap:var(--space-16); padding-block:var(--space-12); }
  .product-gallery__main { aspect-ratio:1/1; overflow:hidden; background:var(--color-bg-alt); }
  .product-gallery__image { width:100%; height:100%; object-fit:cover; }
  .product-gallery__thumbs { display:flex; gap:var(--space-2); margin-top:var(--space-3); }
  .product-gallery__thumb { width:80px; height:80px; overflow:hidden; border:2px solid transparent; cursor:pointer; flex-shrink:0; }
  .product-gallery__thumb.is-active { border-color:var(--color-heading); }
  .product-gallery__thumb img { width:100%; height:100%; object-fit:cover; }
  .product-info__vendor { font-size:var(--text-xs); font-weight:var(--weight-bold); letter-spacing:var(--tracking-widest); text-transform:uppercase; color:var(--color-text-muted); margin-bottom:var(--space-2); }
  .product-info__title { font-size:var(--text-h2); margin-bottom:var(--space-4); }
  .product-info__price { margin-bottom:var(--space-6); }
  .product-info__description { font-size:var(--text-base); line-height:var(--leading-relaxed); color:var(--color-text); margin-bottom:var(--space-8); }
  .product-form__qty { margin-top:var(--space-5); }
  .product-tab { border-bottom:1px solid var(--color-border); }
  .product-tab__trigger { width:100%; text-align:left; padding:var(--space-4) 0; font-weight:var(--weight-bold); font-size:var(--text-base); color:var(--color-heading); cursor:pointer; display:flex; justify-content:space-between; align-items:center; }
  .product-tab__trigger::after { content:'＋'; transition:transform var(--transition-base); }
  .product-tab.is-open .product-tab__trigger::after { transform:rotate(45deg); }
  .product-tab__content { display:none; padding-bottom:var(--space-4); font-size:var(--text-base); color:var(--color-text); line-height:var(--leading-relaxed); }
  .product-tab.is-open .product-tab__content { display:block; }
  @media(max-width:767px){ .product-layout{ grid-template-columns:1fr; gap:var(--space-8); } }
</style>

<script src="{{ 'product-form.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Product",
  "settings": [],
  "blocks": [{
    "type": "tab",
    "name": "Tab",
    "settings": [
      { "type": "text", "id": "heading", "label": "Tab heading", "default": "Description" },
      { "type": "richtext", "id": "content", "label": "Tab content" }
    ]
  }],
  "presets": [{ "name": "Product" }]
}
{% endschema %}
