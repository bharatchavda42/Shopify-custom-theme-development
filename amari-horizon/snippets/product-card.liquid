{%- liquid
  assign card_product = product
  assign show_badges = true
  assign has_sale = false
  if card_product.compare_at_price > card_product.price and card_product.available
    assign has_sale = true
  endif
-%}
<div class="product-card">
  <a href="{{ card_product.url }}" class="product-card__media" aria-label="{{ card_product.title }}">
    {%- if card_product.featured_media -%}
      <img class="product-card__image"
           src="{{ card_product.featured_media | image_url: width: 600 }}"
           srcset="{{ card_product.featured_media | image_url: width: 400 }} 400w,
                   {{ card_product.featured_media | image_url: width: 600 }} 600w,
                   {{ card_product.featured_media | image_url: width: 800 }} 800w"
           sizes="(max-width:479px) 100vw, (max-width:767px) 50vw, (max-width:1199px) 33vw, 25vw"
           alt="{{ card_product.featured_media.alt | default: card_product.title }}"
           loading="lazy"
           width="600" height="600">
    {%- else -%}
      <div style="width:100%;height:100%;background:var(--color-bg-alt);"></div>
    {%- endif -%}

    {%- if show_badges -%}
      <div class="product-card__badges">
        {%- if has_sale -%}
          <span class="badge badge--sale">{{ 'products.product.sale' | t }}</span>
        {%- endif -%}
        {%- for tag in card_product.tags -%}
          {%- if tag == 'best-seller' or tag == 'Best Seller' or tag == 'BEST SELLER' -%}
            <span class="badge badge--bestseller">Best Seller</span>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </a>

  <div class="product-card__info">
    {%- if card_product.vendor != blank -%}
      <span class="product-card__vendor">{{ card_product.vendor }}</span>
    {%- endif -%}
    <a href="{{ card_product.url }}" class="product-card__title">{{ card_product.title }}</a>
    <div class="product-card__price">
      {%- render 'price', product: card_product -%}
    </div>
  </div>
</div>
